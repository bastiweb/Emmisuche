APP_NAME="Emmi Kocht Einfach Suche"
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true
HOST=127.0.0.1
PORT=8910

DATABASE_PATH=/var/lib/emmisuche/recipes.db
RESULTS_PER_PAGE=10

SITEMAP_INDEX_URL=https://emmikochteinfach.de/sitemap_index.xml
ALLOWED_DOMAIN=emmikochteinfach.de
CRAWLER_USER_AGENT="EmmiRecipeSearchBot/1.0 (+personal-local-use; respectful-crawl)"
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_DELAY_SECONDS=1.0
CRAWLER_RATE_LIMIT_PER_MINUTE=0
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_BACKOFF_BASE_SECONDS=1.0
CRAWLER_RETRY_BACKOFF_MAX_SECONDS=16.0
CRAWLER_RETRY_JITTER_SECONDS=0.5
CRAWLER_RETRY_STATUS_CODES=429,500,502,503,504
CRAWLER_MAX_PAGES=0
CRAWLER_STALE_DAYS=30
CRAWLER_MIN_FETCH_INTERVAL_HOURS=6
CRAWLER_FAILURE_RETRY_HOURS=12
CRAWLER_NON_RECIPE_RECHECK_DAYS=90
CRAWLER_DISALLOWED_RECHECK_DAYS=7
CRAWLER_INCLUDE_SITEMAP_KEYWORDS=post-sitemap,page-sitemap,recipe-sitemap
CRAWLER_INCLUDE_URL_KEYWORDS=
CRAWLER_ALLOW_NON_HTTPS=false
